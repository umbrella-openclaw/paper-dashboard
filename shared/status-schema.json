{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "task_id": { "type": "string" },
    "stage": { 
      "type": "string",
      "enum": ["INTAKE", "LITERATURE", "OUTLINE", "DATA_REQUIREMENTS", "DRAFTING", "POLISHING", "REVIEW", "FINALIZE"]
    },
    "stage_status": {
      "type": "string",
      "enum": ["idle", "processing", "waiting_confirm", "completed", "error"]
    },
    "progress": {
      "type": "object",
      "properties": {
        "papers_processed": { "type": "number" },
        "papers_total": { "type": "number" },
        "topics_generated": { "type": "number" }
      }
    },
    "result": {
      "type": "object"
    },
    "messages": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "timestamp": { "type": "string" },
          "from": { "type": "string" },
          "content": { "type": "string" }
        }
      }
    },
    "error": {
      "type": "string"
    },
    "updated_at": { "type": "string" }
  }
}
